/* 当前阶段把服务端运行所需的最小配置统一收口到 app.json：
 * - 监听地址和端口；
 * - IO 线程数；
 * - Drogon 日志级别；
 * - PostgreSQL db_clients 配置；
 * - Redis redis_clients 配置；
 * - 本地文件存储目录配置。
 *
 * 这里的开发配置默认走：
 * - PostgreSQL：本机 Unix Socket `/var/run/postgresql` 和本地数据库 `postgres`；
 * - Redis：本机 `127.0.0.1:6379`；
 * - 文件存储：源码树下的 `chatServer/uploads/`。
 */
{
    // listeners: Drogon 服务监听列表。
    // 当前阶段只监听一个 HTTP 端口，后续如果要补 HTTPS 或多端口监听，再继续往数组里加。
    "listeners": [
        {
            // address: 服务监听地址。
            // `0.0.0.0` 表示监听所有网卡，便于本机和局域网联调。
            "address": "0.0.0.0",
            // port: HTTP 服务端口。
            "port": 8848,
            // https: 当前阶段不启用 HTTPS，因此固定为 false。
            "https": false
        }
    ],
    // db_clients: Drogon 数据库客户端配置列表。
    // 当前阶段只保留一个默认 PostgreSQL 客户端。
    "db_clients": [
        {
            // name: 数据库客户端名字。
            // 后续代码通过这个名字获取客户端，当前统一使用 default。
            "name": "default",
            // rdbms: 数据库类型。
            // 当前项目固定使用 postgresql。
            "rdbms": "postgresql",
            // host: PostgreSQL 主机地址。
            // 当前开发环境走 Unix Socket 目录，而不是 TCP 地址。
            "host": "/var/run/postgresql",
            // port: PostgreSQL 端口。
            "port": 5432,
            // dbname: 默认连接的数据库名。
            "dbname": "chatserver",
            // user: 数据库用户名。
            // 当前按本地开发环境配置填写。
            "user": "wumo",
            // passwd: 数据库密码。
            // 当前按本地开发环境配置填写。
            "passwd": "123456",
            // is_fast: 是否启用 fast client。
            // 当前先关闭，避免后续误用同步接口时踩到限制。
            "is_fast": false,
            // number_of_connections: 数据库连接数。
            // 脚手架阶段保持 1，后续按真实并发量调整。
            "number_of_connections": 1,
            // timeout: 单条 SQL 执行超时时间，单位秒。
            // 小于等于 0 表示不设置超时。
            "timeout": 5.0
        }
    ],
    // redis_clients: Drogon Redis 客户端配置列表。
    // 当前项目只保留一个默认 Redis 客户端，用于后续在线状态、短期缓存和健康检查。
    "redis_clients": [
        {
            // name: Redis 客户端名字。
            // 当前统一使用 default，后续代码通过这个名字获取 Redis client。
            "name": "default",
            // host: Redis 服务地址。
            "host": "127.0.0.1",
            // port: Redis 端口。
            "port": 6379,
            // username: Redis ACL 用户名。
            // 当前本地开发环境未启用 ACL，因此留空。
            "username": "",
            // passwd: Redis 密码。
            // 当前本地开发环境未设置密码，因此留空。
            "passwd": "",
            // db: Redis 逻辑库编号。
            "db": 0,
            // is_fast: 是否启用 fast redis client。
            // 当前先关闭，避免脚手架阶段误用同步接口限制。
            "is_fast": false,
            // number_of_connections: Redis 连接数。
            "number_of_connections": 1,
            // timeout: Redis 命令超时时间，单位秒。
            "timeout": 5.0
        }
    ],
    // chatserver: 项目自定义配置。
    // 当前主要用于统一日志模块的输出策略，不影响 Drogon 对 listeners / db_clients 的解析。
    "chatserver": {
        "auth": {
            // access_token_secret: access token 签名密钥。
            // 当前第一版 access token 会把用户和 device_session 信息编码进去，并用这个密钥做签名。
            "access_token_secret": "chatserver-dev-secret-change-me",
            // access_token_expires_in_sec: access token 有效时长，单位秒。
            "access_token_expires_in_sec": 7200,
            // refresh_token_expires_in_sec: refresh token 有效时长，单位秒。
            "refresh_token_expires_in_sec": 2592000
        },
        "storage": {
            // provider: 当前文件存储实现类型。
            // 现阶段先固定使用 local，本地目录联调通过后再补 MinIO 实现。
            "provider": "local",
            "local": {
                // root_dir: 文件存储根目录。
                // 相对路径会以 app.json 所在目录为基准解析；`../uploads` 最终落到 chatServer/uploads/。
                "root_dir": "../uploads",
                // tmp_dir: 临时文件目录。
                // 相对路径会以 root_dir 为基准解析，上传中断或分块合并时可复用。
                "tmp_dir": "tmp",
                // attachments_dir: 聊天图片、文件等附件目录。
                // 图片和普通文件当前统一先落到附件目录，再通过 content_type 区分。
                "attachments_dir": "files",
                // avatars_dir: 用户头像目录。
                "avatars_dir": "avatars"
            }
        },
        "log": {
            // app_name: 日志前缀中的应用名。
            // 当前统一保持为 chatServer，便于和后续客户端或其它进程日志区分。
            "app_name": "chatServer",
            // enable_console: 是否输出到控制台。
            // 开发阶段保持开启，便于终端联调。
            "enable_console": true,
            // enable_file: 是否同时写入日志文件。
            // 当前默认开启，便于后续排查启动和业务错误。
            "enable_file": true,
            // directory: 日志目录。
            // 相对路径会以 app.json 所在目录为基准解析；`../logs` 最终落到 chatServer/logs/。
            "directory": "../logs",
            // file_name: 当前进程日志文件名。
            "file_name": "chatserver.log"
        }
    },
    // app: Drogon 应用级配置。
    "app": {
        // number_of_threads: IO 工作线程数。
        // 设为 0 时，Drogon 会按 CPU 核心数自动选择线程数。
        "number_of_threads": 0,
        // enable_session: 当前阶段不开启 HTTP Session。
        "enable_session": false,
        // idle_connection_timeout: 空闲连接超时时间，单位秒。
        "idle_connection_timeout": 60,
        // log: Drogon 日志配置。
        "log": {
            // log_level: 当前脚手架阶段保持 INFO，便于联调时看到关键启动日志。
            "log_level": "INFO",
            // display_local_time: 日志时间使用本地时区显示，便于本机排障。
            "display_local_time": true
        }
    }
}
